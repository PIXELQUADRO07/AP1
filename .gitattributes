# Language detection configuration for GitHub
# This file tells GitHub how to properly categorize languages in the repository

# Ignore CSS, SCSS, and Less files (not part of the project)
*.css linguist-vendored=true
*.scss linguist-vendored=true
*.less linguist-vendored=true

# Explicitly mark Rust files
*.rs linguist-language=Rust

# Explicitly mark Go files
*.go linguist-language=Go

# Ignore build artifacts and generated files
target/ linguist-vendored=true
vendor/ linguist-vendored=true
node_modules/ linguist-vendored=true
*.o linguist-vendored=true
*.a linguist-vendored=true

# Mark configuration files
Makefile linguist-language=Makefile
*.yaml linguist-language=YAML
*.yml linguist-language=YAML
*.sh linguist-language=Shell
