#!/usr/bin/env bash
# AP1 Ultra-Fast Silent Launcher with Dynamic Interface Support
set -eo pipefail

# Colors
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
BIN_DIR="$ROOT_DIR/bin"
LOG_DIR="$ROOT_DIR/system/runtime/logs"
CORE_BIN="$ROOT_DIR/core/target/debug/ap1_core"
API_BIN="$BIN_DIR/ap1-api"
CLI_BIN="$BIN_DIR/ap1-cli"

cd "$ROOT_DIR"
mkdir -p "$BIN_DIR" "$LOG_DIR"

if [ "$EUID" -ne 0 ]; then
  echo -e "${RED}[!] Permission denied. Re-executing with sudo...${NC}"
  exec sudo "$SCRIPT_PATH" "$@"
fi

# 1. Interface Discovery & Validation
AVAILABLE_IFACES=($(iw dev | awk '$1=="Interface"{print $2}'))

function list_interfaces() {
    echo -e "${CYAN}Available Wi-Fi interfaces:${NC}"
    for iface in "${AVAILABLE_IFACES[@]}"; do
        echo -e " - ${GREEN}$iface${NC}"
    done
}

SELECTED_IFACE=""
if [[ "${1:-}" != "--rebuild" && -n "${1:-}" ]]; then
    # User specified an interface
    for iface in "${AVAILABLE_IFACES[@]}"; do
        if [[ "$iface" == "$1" ]]; then
            SELECTED_IFACE="$1"
            break
        fi
    done
    if [[ -z "$SELECTED_IFACE" ]]; then
        echo -e "${RED}[!] Error: Interface '$1' not found or is not a Wi-Fi device.${NC}"
        list_interfaces
        exit 1
    fi
else
    # Auto-detect first available
    SELECTED_IFACE="${AVAILABLE_IFACES[0]:-}"
    if [ -z "$SELECTED_IFACE" ]; then
        echo -e "${RED}[!] No Wi-Fi interface detected. Please connect a Wi-Fi card.${NC}"
        exit 1
    fi
fi

function build_if_needed() {
    local rebuild=false
    if [[ "${1:-}" == "--rebuild" || "${2:-}" == "--rebuild" ]] || [ ! -f "$CORE_BIN" ] || [ ! -f "$API_BIN" ] || [ ! -f "$CLI_BIN" ]; then
        rebuild=true
    fi

    if [ "$rebuild" = true ]; then
        echo -n -e "${YELLOW}[>] Preparing AP1 environment... ${NC}"
        cd "$ROOT_DIR/core" && cargo build -q > /dev/null 2>&1 || (echo -e "${RED}Core Build Failed${NC}" && exit 1)
        cd "$ROOT_DIR/api" && go build -o "$API_BIN" main.go > /dev/null 2>&1 || (echo -e "${RED}API Build Failed${NC}" && exit 1)
        cd "$ROOT_DIR/cli" && go build -o "$CLI_BIN" main.go repl.go tui.go > /dev/null 2>&1 || (echo -e "${RED}CLI Build Failed${NC}" && exit 1)
        echo -e "${GREEN}Ready!${NC}"
    fi
}

function start_services() {
    pkill -f "ap1_core" || true
    pkill -f "ap1-api" || true

    export AP1_IFACE="$SELECTED_IFACE"

    cd "$ROOT_DIR/core"
    "$ROOT_DIR/core/target/debug/ap1_core" > "$LOG_DIR/core.log" 2>&1 &
    CORE_PID=$!

    cd "$ROOT_DIR/api"
    "$ROOT_DIR/bin/ap1-api" -addr ":8001" > "$LOG_DIR/api.log" 2>&1 &
    API_PID=$!

    cd "$ROOT_DIR"

    sleep 0.8
    if ! ps -p $CORE_PID > /dev/null; then
        echo -e "${RED}[!] Core failed to start. Check $LOG_DIR/core.log${NC}"
        exit 1
    fi
}

function cleanup() {
    echo -e "\n${RED}[!] Shutting down AP1...${NC}"
    pkill -f "ap1_core" || true
    pkill -f "ap1-api" || true
    exit 0
}
trap cleanup EXIT INT TERM

# Main
clear
echo -e "${CYAN}"
cat << "EOF"
 .+"+.+"+.+"+.+"+.+"+.+"+.+"+.+"+.+"+.+"+.
(        _           ____         _       )
 )      / \         |  _ \       / |     (
(      / _ \        | |_) |      | |      )
 )    / ___ \       |  __/       | |     (
(    /_/   \_\      |_|          |_|      )
 )                                       (
(                                         )
 "+.+"+.+"+.+"+.+"+.+"+.+"+.+"+.+"+.+"+.+"
EOF
echo -e "      AP1 - Rogue AP Orchestrator${NC}\n"
echo -e "${GREEN}[*] Target Interface: $SELECTED_IFACE${NC}"

build_if_needed "$@"
start_services

"$CLI_BIN" interactive
