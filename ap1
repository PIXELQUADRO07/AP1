#!/usr/bin/env bash
# AP1 Ultra-Fast Silent Launcher with Dynamic Interface Support
set -eo pipefail

# Colors
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
BIN_DIR="$ROOT_DIR/bin"
LOG_DIR="$ROOT_DIR/system/runtime/logs"
CORE_BIN="$ROOT_DIR/core/target/debug/ap1_core"
API_BIN="$BIN_DIR/ap1-api"
CLI_BIN="$BIN_DIR/ap1-cli"

cd "$ROOT_DIR"
mkdir -p "$BIN_DIR" "$LOG_DIR"

if [ "$EUID" -ne 0 ]; then
  echo -e "${RED}[!] Permission denied. Re-executing with sudo...${NC}"
  exec sudo "$SCRIPT_PATH" "$@"
fi

COMMAND="${1:-}"
if [[ "$COMMAND" == "--rebuild" ]]; then
    REBUILD=true
    shift
    COMMAND="${1:-}"
fi

# 1. Interface Discovery & Validation
AVAILABLE_IFACES=($(iw dev | awk '$1=="Interface"{print $2}'))

function list_interfaces() {
    echo -e "${CYAN}Available Wi-Fi interfaces:${NC}"
    for iface in "${AVAILABLE_IFACES[@]}"; do
        echo -e " - ${GREEN}$iface${NC}"
    done
}

SELECTED_IFACE=""
if [[ -n "${2:-}" ]]; then
    for iface in "${AVAILABLE_IFACES[@]}"; do
        if [[ "$iface" == "${2:-}" ]]; then
            SELECTED_IFACE="${2:-}"
            break
        fi
    done
    if [[ -z "$SELECTED_IFACE" ]]; then
        echo -e "${RED}[!] Error: Interface '${2:-}' not found or is not a Wi-Fi device.${NC}"
        list_interfaces
        exit 1
    fi
else
    SELECTED_IFACE="${AVAILABLE_IFACES[0]:-}"
    if [ -z "$SELECTED_IFACE" ]; then
        echo -e "${RED}[!] No Wi-Fi interface detected. Please connect a Wi-Fi card.${NC}"
        exit 1
    fi
fi

function usage() {
    cat <<EOF
Usage: $0 <command> [interface]

Commands:
  start         Build and start AP1 core and API services
  stop          Stop AP1 core and API services
  status        Show AP1 core and API service status
  interactive   Launch the AP1 interactive CLI (starts services if needed)
  help          Show this help message

Examples:
  $0 start
  $0 stop
  $0 status
  $0 interactive
  $0 start wlan0
EOF
}

function is_running() {
    pgrep -f "$1" >/dev/null 2>&1
}

function build_components() {
    echo -n -e "${YELLOW}[>] Checking/Building AP1 components... ${NC}"
    cd "$ROOT_DIR/core" && cargo build -q > /dev/null 2>&1 || (echo -e "${RED}Core Build Failed${NC}" && exit 1)
    cd "$ROOT_DIR/api" && go build -o "$API_BIN" main.go > /dev/null 2>&1 || (echo -e "${RED}API Build Failed${NC}" && exit 1)
    cd "$ROOT_DIR/cli" && go build -o "$CLI_BIN" main.go repl.go tui.go > /dev/null 2>&1 || (echo -e "${RED}CLI Build Failed${NC}" && exit 1)
    echo -e "${GREEN}Ready!${NC}"
}

function start_services() {
    export AP1_IFACE="$SELECTED_IFACE"

    if ! is_running "ap1_core"; then
        echo -n -e "${YELLOW}[>] Starting core service... ${NC}"
        cd "$ROOT_DIR/core"
        "$CORE_BIN" > "$LOG_DIR/core.log" 2>&1 &
        CORE_PID=$!
        sleep 1
        if ! ps -p $CORE_PID >/dev/null 2>&1; then
            echo -e "${RED}Failed${NC}"
            echo -e "Check $LOG_DIR/core.log for details."
            exit 1
        fi
        echo -e "${GREEN}Started${NC}"
    else
        echo -e "${GREEN}[+] Core already running${NC}"
    fi

    if ! is_running "ap1-api"; then
        echo -n -e "${YELLOW}[>] Starting API service... ${NC}"
        cd "$ROOT_DIR/api"
        "$API_BIN" -config "$ROOT_DIR/config/global.yaml" -plugins "$ROOT_DIR/config/plugins.yaml" -addr ":8001" > "$LOG_DIR/api.log" 2>&1 &
        API_PID=$!
        sleep 1
        if ! ps -p $API_PID >/dev/null 2>&1; then
            echo -e "${RED}Failed${NC}"
            echo -e "Check $LOG_DIR/api.log for details."
            exit 1
        fi
        echo -e "${GREEN}Started${NC}"
    else
        echo -e "${GREEN}[+] API already running${NC}"
    fi
}

function stop_services() {
    echo -e "${YELLOW}[>] Stopping AP1 services...${NC}"
    pkill -f "ap1_core" || true
    pkill -f "ap1-api" || true
    echo -e "${GREEN}[+] Services stopped${NC}"
}

function status_services() {
    echo -e "${CYAN}AP1 service status:${NC}"
    if is_running "ap1_core"; then
        echo -e "  ${GREEN}Core is running${NC}"
    else
        echo -e "  ${RED}Core is stopped${NC}"
    fi
    if is_running "ap1-api"; then
        echo -e "  ${GREEN}API is running${NC}"
    else
        echo -e "  ${RED}API is stopped${NC}"
    fi
}

CLEANUP_ON_EXIT=false

function launch_cli() {
    echo -e "${CYAN}Launching AP1 interactive CLI...${NC}"
    "$CLI_BIN" interactive
}

function cleanup() {
    if [[ "$CLEANUP_ON_EXIT" != true ]]; then
        return
    fi
    echo -e "\n${RED}[!] Shutting down AP1...${NC}"
    pkill -f "ap1_core" || true
    pkill -f "ap1-api" || true
    exit 0
}
trap cleanup EXIT INT TERM

# Main
clear
echo -e "${CYAN}"
cat << "EOF"
 .+"+.+"+.+"+.+"+.+"+.+"+.+"+.+"+.+"+.+"+.
(        _           ____         _       )
 )      / \         |  _ \       / |     (
(      / _ \        | |_) |      | |      )
 )    / ___ \       |  __/       | |     (
(    /_/   \_\      |_|          |_|      )
 )                                       (
(                                         )
 "+.+"+.+"+.+"+.+"+.+"+.+"+.+"+.+"+.+"+.+"
EOF
echo -e "      AP1 - Rogue AP Orchestrator${NC}\n"
echo -e "${GREEN}[*] Target Interface: $SELECTED_IFACE${NC}"

case "$COMMAND" in
    start)
        build_components
        start_services
        exit 0
        ;;
    stop)
        stop_services
        exit 0
        ;;
    status)
        status_services
        exit 0
        ;;
    interactive|cli)
        build_components
        start_services
        CLEANUP_ON_EXIT=true
        launch_cli
        ;;
    help|"")
        usage
        exit 0
        ;;
    *)
        echo -e "${RED}[!] Unknown command: $COMMAND${NC}"
        usage
        exit 1
        ;;
esac
