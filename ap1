#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
cd "$ROOT_DIR"

if [ "$EUID" -ne 0 ]; then
  echo "This script must run as root to configure network interfaces and hostapd. Re-executing with sudo..."
  exec sudo "$SCRIPT_PATH" "$@"
fi

function path_contains() {
  case ":$PATH:" in
    *":$1:"*) return 0 ;;
    *) return 1 ;;
  esac
}

function install_link() {
  local source="$1"
  local target="$2"
  mkdir -p "$(dirname "$target")"
  ln -sf "$source" "$target"
  chmod +x "$source"
  echo "Installed $(basename "$target") to $target"
  if ! path_contains "$(dirname "$target")"; then
    echo "Warning: $(dirname "$target") is not in PATH."
    echo "Add the following to your shell profile and restart your terminal:"
    echo "  export PATH=\"$(dirname "$target"):\$PATH\""
  fi
}

function install_ap1_link() {
  local target="$1"
  install_link "$SCRIPT_PATH" "$target"
}

function install_ap1_cli_link() {
  local target="$1"
  if [ ! -f "$ROOT_DIR/bin/ap1-cli" ]; then
    echo "Building CLI binary before installation..."
    build_cli
  fi
  install_link "$ROOT_DIR/bin/ap1-cli" "$target"
}

function build_core() {
  if [ ! -f "$ROOT_DIR/core/target/debug/ap1_core" ]; then
    echo "[1/3] Building core..."
    cd "$ROOT_DIR/core"
    cargo build
  fi
}

function build_api() {
  if [ ! -f "$ROOT_DIR/bin/ap1-api" ]; then
    echo "[2/3] Building API..."
    cd "$ROOT_DIR/api"
    go build -o "$ROOT_DIR/bin/ap1-api"
  fi
}

function build_cli() {
  if [ ! -f "$ROOT_DIR/bin/ap1-cli" ]; then
    echo "[3/3] Building CLI..."
    cd "$ROOT_DIR/cli"
    go build -o "$ROOT_DIR/bin/ap1-cli"
  fi
}

function build_all() {
  mkdir -p "$ROOT_DIR/bin"
  build_core
  build_api
  build_cli
}



function ensure_ap1_installed() {
  local current="$(readlink -f "$SCRIPT_PATH" 2>/dev/null || echo "$SCRIPT_PATH")"
  local installed
  installed="$(command -v ap1 2>/dev/null || true)"
  if [ -n "$installed" ]; then
    installed="$(readlink -f "$installed" 2>/dev/null || echo "$installed")"
    if [ "$installed" = "$current" ]; then
      return
    fi
    echo "Note: another 'ap1' command already exists in $installed."
    echo "I will still install a link to ~/.local/bin/ap1 for this copy."
  fi

  if [ -w "/usr/local/bin" ] 2>/dev/null; then
    install_ap1_link "/usr/local/bin/ap1"
    return
  fi

  if mkdir -p "$HOME/.local/bin" 2>/dev/null; then
    install_ap1_link "$HOME/.local/bin/ap1"
    return
  fi

  if mkdir -p "$HOME/bin" 2>/dev/null; then
    install_ap1_link "$HOME/bin/ap1"
    return
  fi

  echo "Cannot install ap1 automatically."
  echo "Create a symlink manually in a PATH directory:"
  echo "  ln -s \"$SCRIPT_PATH\" /usr/local/bin/ap1"
  echo "or"
  echo "  ln -s \"$SCRIPT_PATH\" \"\$HOME/.local/bin/ap1\""
}

function print_help() {
  cat <<'EOF'
Usage: ap1 [command]

Commands:
  start       Build and start AP1 core + API services and open CLI
  install     Build AP1 and prepare the launcher
  help        Show this help message

If no command is provided, AP1 will start core/API in background and open the CLI.

Examples:
  ./ap1
  ./ap1 start
  sudo ./ap1
EOF
}

case "${1:-}" in
  help|-h|--help)
    print_help
    exit 0
    ;;
  install)
    if ! command -v cargo >/dev/null 2>&1; then
      echo "Error: cargo not found. Install Rust before continuing."
      exit 1
    fi
    if ! command -v go >/dev/null 2>&1; then
      echo "Error: go not found. Install Go before continuing."
      exit 1
    fi
    build_cli
    if [ -w "/usr/local/bin" ] 2>/dev/null; then
      install_ap1_link "/usr/local/bin/ap1"
      install_ap1_cli_link "/usr/local/bin/ap1-cli"
    elif mkdir -p "$HOME/.local/bin" 2>/dev/null; then
      install_ap1_link "$HOME/.local/bin/ap1"
      install_ap1_cli_link "$HOME/.local/bin/ap1-cli"
    elif mkdir -p "$HOME/bin" 2>/dev/null; then
      install_ap1_link "$HOME/bin/ap1"
      install_ap1_cli_link "$HOME/bin/ap1-cli"
    else
      echo "Cannot install ap1 automatically."
      echo "Create a symlink manually in a PATH directory:"
      echo "  ln -s \"$SCRIPT_PATH\" /usr/local/bin/ap1"
      echo "or"
      echo "  ln -s \"$ROOT_DIR/bin/ap1-cli\" \"\$HOME/.local/bin/ap1-cli\""
    fi
    echo "AP1 launcher ready. Use 'ap1' from any directory if the symlink was installed correctly."
    exit 0
    ;;
  start|"")
    if ! command -v cargo >/dev/null 2>&1; then
      echo "Error: cargo not found. Install Rust before continuing."
      exit 1
    fi
    if ! command -v go >/dev/null 2>&1; then
      echo "Error: go not found. Install Go before continuing."
      exit 1
    fi
    build_all
    echo "Starting AP1 core and API in background..."
    cd "$ROOT_DIR"
    CORE_BIN="$ROOT_DIR/core/target/debug/ap1_core"
    API_BIN="$ROOT_DIR/bin/ap1-api"
    CLI_BIN="$ROOT_DIR/bin/ap1-cli"

    "$CORE_BIN" &
    CORE_PID=$!
    "$API_BIN" -config "$ROOT_DIR/config/global.yaml" -plugins "$ROOT_DIR/config/plugins.yaml" -addr ":8080" &
    API_PID=$!

    function finish {
      echo "\nStopping AP1..."
      kill "$CORE_PID" "$API_PID" 2>/dev/null || true
    }
    trap finish EXIT INT TERM

    sleep 2
    echo "AP1 started."
    echo "  core PID = $CORE_PID"
    echo "  api  PID = $API_PID"
    echo "Entering AP1 CLI interactive shell. Press Ctrl+C or type 'exit' to stop."

    "$CLI_BIN" interactive
    CLI_STATUS=$?

    finish
    exit "$CLI_STATUS"
    ;;
  *)
    echo "Unknown command: $1"
    print_help
    exit 1
    ;;
esac
